{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": [
    "eslint:recommended"
  ],
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "rules": {
    "indent": ["error", 4],
    "linebreak-style": ["error", "windows"],
    "quotes": ["error", "single"],
    "semi": ["error", "always"],
    "no-unused-vars": "warn",
    "no-console": "off",
    "no-debugger": "warn",
    "no-var": "error",
    "prefer-const": "error",
    "no-undef": "error",
    "no-unused-expressions": "warn",
    "eqeqeq": ["error", "always"],
    "curly": ["error", "all"],
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-new-func": "error",
    "no-return-assign": "error",
    "no-useless-return": "warn",
    "radix": "error",
    "no-shadow": "warn",
    "no-param-reassign": "warn",
    "prefer-arrow-callback": "error",
    "prefer-spread": "error",
    "prefer-template": "error",
    "no-multiple-empty-lines": ["error", { "max": 2 }],
    "no-trailing-spaces": "error",
    "eol-last": "error",
    "space-in-parens": ["error", "never"],
    "space-before-blocks": "error",
    "keyword-spacing": "error",
    "space-infix-ops": "error",
    "space-unary-ops": "error",
    "no-mixed-operators": "warn",
    "no-nested-ternary": "warn",
    "no-unneeded-ternary": "error",
    "no-lonely-if": "error",
    "yoda": "error",
    "no-else-return": "error",
    "dot-notation": "error",
    "no-extra-bind": "error",
    "no-lone-blocks": "error",
    "no-new-wrappers": "error",
    "no-self-compare": "error",
    "no-sequences": "error",
    "no-throw-literal": "error",
    "no-unused-labels": "error",
    "no-useless-call": "error",
    "no-useless-concat": "error",
    "no-useless-escape": "error",
    "wrap-iife": "error",
    "no-new": "warn",
    "no-fallthrough": "warn",
    "no-case-declarations": "warn"
  },
  "globals": {
    "$": "readonly",
    "$$on": "readonly",
    "$$event": "readonly",
    "$$eventMap": "readonly",
    "domtoimage": "readonly",
    "localStorage": "readonly",
    "navigator": "readonly",
    "caches": "readonly",
    "self": "readonly",
    "json": "readonly"
  },
  "ignorePatterns": [
    "node_modules/",
    "public/",
    "lib/",
    "view/",
    "data/",
    "*.json"
  ]
}
